# ─── Required — Supabase ────────────────────────────────────────────────────
# Server-side only — used in api/*.js; never expose to the browser
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=      # Server-side only — never expose to browser
SUPABASE_SERVICE_ROLE_KEY= # Alias used in some api/ functions (same value as SUPABASE_SERVICE_KEY)

# Public — embedded in the browser bundle (Vite exposes these as import.meta.env.*)
VITE_SUPABASE_URL=https://your-project.supabase.co  # Public — safe to expose
VITE_SUPABASE_ANON_KEY=                              # Public — safe to expose

# ─── Required — API Auth ────────────────────────────────────────────────────
GATEWAY_SECRET=            # Shared secret for x-gateway-secret header on API routes
ALLOWED_ORIGIN=            # CORS allowed origin — defaults to https://gatewayhq.github.io

# ─── Optional — AI (features degrade gracefully without these) ──────────────
ANTHROPIC_API_KEY=         # AI email drafting + flyer generation (api/claude.js)

# ─── Optional — DocuSign e-signature ────────────────────────────────────────
DOCUSIGN_INTEGRATION_KEY=  # OAuth integration key from DocuSign Apps & Keys
DOCUSIGN_ACCOUNT_ID=       # DocuSign account ID (GUID)
DOCUSIGN_USER_ID=          # DocuSign user ID (GUID) for JWT impersonation
DOCUSIGN_AUTH_SERVER=      # e.g. account-d.docusign.com (sandbox) or account.docusign.com (prod)
DOCUSIGN_PRIVATE_KEY=      # RSA private key (PEM) — use \n for newlines in Vercel

# ─── Optional — Twilio SMS/Voice ────────────────────────────────────────────
TWILIO_ACCOUNT_SID=        # Twilio Account SID (starts with AC)
TWILIO_AUTH_TOKEN=         # Twilio Auth Token — server-side only
TWILIO_FROM_NUMBER=        # Twilio phone number in E.164 format, e.g. +15551234567

# ─── Optional — Buffer social scheduling ────────────────────────────────────
BUFFER_ACCESS_TOKEN=       # Buffer OAuth access token for social post scheduling
