# ─────────────────────────────────────────────────────────────────────────────
# Gateway CRM — Environment Variables
# Copy this file to .env.local for local dev, or add to Vercel → Settings →
# Environment Variables for production.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (required) ──────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Service role key — used by server-side API routes only (never expose to browser)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key   # Supabase → Settings → API → service_role

# ── Email Sending via Resend (add to Vercel to enable sequences + server-side send) ──
# Get your API key at resend.com → API Keys
# RESEND_FROM must be a domain you've verified in Resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM="Gateway Real Estate <hello@yourdomain.com>"

# ── Cron Security ────────────────────────────────────────────────────────────
# Protects /api/sequence-run from being triggered by anyone other than Vercel cron.
# Generate with: openssl rand -hex 32
GATEWAY_CRON_SECRET=your-random-secret-here

# ── Twilio SMS (optional — configure in app Settings → Integrations) ─────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token

# ── DocuSign (optional — configure in app Settings → Integrations) ───────────
DOCUSIGN_INTEGRATION_KEY=your-integration-key
DOCUSIGN_PRIVATE_KEY=your-private-key
DOCUSIGN_USER_ID=your-user-id
DOCUSIGN_ACCOUNT_ID=your-account-id
DOCUSIGN_AUTH_SERVER=account-d.docusign.com   # use account.docusign.com for production

# ── AI / Claude (optional — agents can also set their own key in Settings) ───
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
