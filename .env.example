# ─────────────────────────────────────────────────────────────────────────────
# Gateway CRM — Environment Variables
# Copy this file to .env.local for local dev, or add to Vercel → Settings →
# Environment Variables for production.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (required) ──────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Service role key — used by server-side API routes only (never expose to browser)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key   # Supabase → Settings → API → service_role

# ── Email Sending via Resend (add to Vercel to enable sequences + server-side send) ──
# Get your API key at resend.com → API Keys
# RESEND_FROM must be a domain you've verified in Resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM="Gateway Real Estate <hello@yourdomain.com>"

# ── Cron Security ────────────────────────────────────────────────────────────
# Protects /api/sequence-run from being triggered by anyone other than Vercel cron.
# Generate with: openssl rand -hex 32
GATEWAY_CRON_SECRET=your-random-secret-here

# ── Twilio SMS (optional — configure in app Settings → Integrations) ─────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token

# ── BoldSign e-signature (optional) ──────────────────────────────────────────
# Get an API key at app.boldsign.com → Settings → API → API Keys.
# Sandbox vs Live is decided by WHICH key you generate — a Sandbox key never
# sends real email or consumes credits, so use one while developing. There is no
# separate test-mode flag. US region uses the default base URL below; EU-hosted
# accounts should change API_BASE in api/boldsign.js to https://api-eu.boldsign.com/v1.
BOLDSIGN_API_KEY=your-boldsign-api-key

# ── AI / Claude (optional — agents can also set their own key in Settings) ───
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ── Buffer social posting (optional) ────────────────────────────────────────
BUFFER_ACCESS_TOKEN=your-buffer-token

# ── Branded QR / short-link domain (optional) ────────────────────────────────
# By default, mailing QR codes point at this app's own URL (e.g. your-app.vercel.app).
# To look more professional and hide the CRM's real URL, register a short domain
# (e.g. gatewayre.link or gre.homes), point it at this Vercel project, then set:
#   VITE_PUBLIC_LINK_DOMAIN=https://gatewayre.link
# All QR codes then become https://gatewayre.link/m/<token>. The /m/:token rewrite
# already handles the scan-tracking redirect, so no extra config is needed.
# VITE_PUBLIC_LINK_DOMAIN=https://gatewayre.link

# ── CORS override (optional) ─────────────────────────────────────────────────
# Defaults to * (all origins). Set to your production domain to restrict:
# ALLOWED_ORIGIN=https://your-app.vercel.app

# ── Logging — Logtrail (optional, https://logtrail.net) ──────────────────────
# 1. Sign up at app.logtrail.net (free plan available, no credit card required)
# 2. Go to Settings → API Keys → create a key with write (wo) or rw scope
# 3. Use a lt_production_... key for Vercel production, lt_development_... for local dev
# 4. Add the key here — logs will start appearing in Logtrail immediately
# LOGTRAIL_API_KEY=lt_production_xxxxxxxxxxxxxxxxxxxx
