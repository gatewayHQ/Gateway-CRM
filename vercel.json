{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    { "source": "/share/:id", "destination": "/api/share?id=:id" },
    { "source": "/((?!api/)(?!share/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/docusign-webhook.js": { "maxDuration": 30 },
    "api/sequence-run.js":     { "maxDuration": 60 },
    "api/email-send.js":       { "maxDuration": 15 }
  },
  "crons": [
    { "path": "/api/sequence-run", "schedule": "*/15 * * * *" }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" },
        { "key": "Pragma",        "value": "no-cache" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
