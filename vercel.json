{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm ci --no-audit --no-fund",
  "framework": "vite",
  "crons": [
    { "path": "/api/cron?task=sequence",       "schedule": "0 9 * * *" },
    { "path": "/api/cron?task=reminders",      "schedule": "0 8 * * *" },
    { "path": "/api/cron?task=nudges",         "schedule": "0 14 * * *" },
    { "path": "/api/cron?task=boldsign-sync",  "schedule": "0 3 * * *" }
  ],
  "rewrites": [
    { "source": "/m/:token",  "destination": "/api/campaigns?action=scan&token=:token" },
    { "source": "/share/:id", "destination": "/api/property-public?id=:id" },
    { "source": "/lp/property/:id",
      "has": [{ "type": "header", "key": "user-agent", "value": "(?i).*(facebookexternalhit|facebot|twitterbot|linkedinbot|slackbot|slack-imgproxy|whatsapp|telegrambot|discordbot|pinterest|redditbot|embedly|skypeuripreview|applebot|googlebot|bingbot|iframely|vkshare).*" }],
      "destination": "/api/campaigns?action=og&id=:id&lt=property" },
    { "source": "/lp/valuation/:id",
      "has": [{ "type": "header", "key": "user-agent", "value": "(?i).*(facebookexternalhit|facebot|twitterbot|linkedinbot|slackbot|slack-imgproxy|whatsapp|telegrambot|discordbot|pinterest|redditbot|embedly|skypeuripreview|applebot|googlebot|bingbot|iframely|vkshare).*" }],
      "destination": "/api/campaigns?action=og&id=:id&lt=valuation" },
    { "source": "/lp/multifamily/:id",
      "has": [{ "type": "header", "key": "user-agent", "value": "(?i).*(facebookexternalhit|facebot|twitterbot|linkedinbot|slackbot|slack-imgproxy|whatsapp|telegrambot|discordbot|pinterest|redditbot|embedly|skypeuripreview|applebot|googlebot|bingbot|iframely|vkshare).*" }],
      "destination": "/api/campaigns?action=og&id=:id&lt=multifamily" },
    { "source": "/lp/mailing/:id",
      "has": [{ "type": "header", "key": "user-agent", "value": "(?i).*(facebookexternalhit|facebot|twitterbot|linkedinbot|slackbot|slack-imgproxy|whatsapp|telegrambot|discordbot|pinterest|redditbot|embedly|skypeuripreview|applebot|googlebot|bingbot|iframely|vkshare).*" }],
      "destination": "/api/campaigns?action=og&id=:id&lt=mailing" },
    { "source": "/((?!api/)(?!share/)(?!m/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" },
        { "key": "Pragma",        "value": "no-cache" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
